rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuarios: solo pueden leer/editar su propio perfil
    // Solo la Cloud Function (admin SDK) puede cambiar el rol
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Videos: lectura pública, escritura solo admin
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Pagos: solo admin puede leer, solo Cloud Function (admin SDK) puede escribir
    match /pagos/{pagoId} {
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if false; // Solo escribe la Cloud Function via Admin SDK
    }
  }
}
